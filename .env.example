# ─── Database (Vercel Postgres) ───────────────────────────────────────────────
# Pooled connection (used by application at runtime)
POSTGRES_PRISMA_URL="postgresql://user:password@host:5432/dbname?pgbouncer=true&connect_timeout=15"
# Direct connection (used by Prisma migrations)
POSTGRES_URL_NON_POOLING="postgresql://user:password@host:5432/dbname"

# ─── Auth.js v5 ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
# Full URL of your app (e.g. https://virtuoso.vercel.app)
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── GitHub OAuth ─────────────────────────────────────────────────────────────
# https://github.com/settings/developers → New OAuth App
# Authorization callback URL: https://yourdomain.com/api/auth/callback/github
GITHUB_ID=""
GITHUB_SECRET=""

# ─── Apple OAuth ──────────────────────────────────────────────────────────────
# https://developer.apple.com/account/resources/identifiers
# APPLE_ID: Your Services ID (e.g. com.yourcompany.virtuoso)
# APPLE_CLIENT_SECRET: Pre-generated JWT from your .p8 key (valid up to 6 months)
#   Generate with: node -e "require('./src/lib/apple-secret').generateAppleSecret().then(console.log)"
# Return URL: https://yourdomain.com/api/auth/callback/apple
APPLE_ID=""
APPLE_CLIENT_SECRET=""
# Only needed to re-generate APPLE_CLIENT_SECRET:
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""   # Contents of .p8 file with \n for newlines

# ─── Cloudflare R2 (file uploads) ────────────────────────────────────────────
# Dashboard → R2 → Create bucket, then Manage R2 API Tokens for credentials
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
# Public URL for the bucket — enable "Allow Access" in bucket settings (r2.dev subdomain)
# or connect a custom domain. e.g. https://pub-xxxx.r2.dev or https://files.yourdomain.com
R2_PUBLIC_URL=""
