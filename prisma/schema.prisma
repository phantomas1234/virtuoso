generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // directUrl uses the non-pooling connection for migrations.
  // PgBouncer (used by Neon's pooled URL) blocks the advisory locks
  // that `prisma migrate deploy` requires.
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  goals    Goal[]
}

model Goal {
  id             String     @id @default(cuid())
  userId         String
  title          String
  description    String?    @db.Text
  goalType       GoalType   @default(OPEN)
  targetBpm      Int?
  splitHands     Boolean    @default(false)
  status         GoalStatus @default(ACTIVE)
  position       Int
  youtubeUrl     String?
  accomplishedAt DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  progressEntries ProgressEntry[]
  attachments     Attachment[]
  drumScores      DrumScore[]

  @@index([userId, position])
}

enum GoalType {
  BPM
  OPEN
}

enum GoalStatus {
  ACTIVE
  ACCOMPLISHED
  ARCHIVED
}

enum Hand {
  LEFT
  RIGHT
}

model ProgressEntry {
  id        String   @id @default(cuid())
  goalId    String
  bpm       Int?
  hand      Hand?
  note      String?  @db.Text
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId, date])
}

model Attachment {
  id             String         @id @default(cuid())
  goalId         String
  userId         String
  name           String
  url            String
  fileKey        String?
  mimeType       String
  attachmentType AttachmentType
  size           Int?
  createdAt      DateTime       @default(now())

  goal      Goal       @relation(fields: [goalId], references: [id], onDelete: Cascade)
  drumScore DrumScore?

  @@index([goalId])
}

enum AttachmentType {
  PDF
  VIDEO
  IMAGE
  AUDIO
  OTHER
}

model DrumScore {
  id           String          @id @default(cuid())
  attachmentId String          @unique
  goalId       String
  userId       String
  data         Json?
  suggestedBpm Int?
  status       DrumScoreStatus @default(PENDING)
  errorMessage String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  attachment Attachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  goal       Goal       @relation(fields: [goalId], references: [id], onDelete: Cascade)
}

enum DrumScoreStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}
